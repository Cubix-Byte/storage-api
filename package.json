{
  "name": "storage-api",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "local": "ts-node -r tsconfig-paths/register src/server.ts",
    "debug": "node --inspect-brk=9229 -r ts-node/register -r tsconfig-paths/register src/server.ts",
    "debug:simple": "node debug-server.js",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "keywords": [
    "nodejs",
    "mongodb",
    "express",
    "typescript",
    "storage",
    "s3",
    "file-upload",
    "microservice"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "File Storage Microservice with AWS S3 Integration",
  "dependencies": {
    "shared-lib": "1.0.32",
    "@aws-sdk/client-s3": "^3.478.0",
    "@aws-sdk/s3-request-presigner": "^3.478.0",
    "compression": "^1.8.0",
    "cors": "2.8.5",
    "dotenv": "17.2.2",
    "express": "5.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "tsc-alias": "^1.8.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.11",
    "@types/node": "24.3.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.0.4",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
